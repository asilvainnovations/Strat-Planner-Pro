# Supabase Configuration
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# PWA Configuration
VITE_PWA_EXTERNAL_URL=https://asilvainnovations.github.io/strat-planner-pwa/index.html

# AI Gateway Configuration (Famous AI)
VITE_AI_GATEWAY_URL=https://api.fireworks.ai/v1
VITE_AI_GATEWAY_KEY=your-gateway-key-here

# Analytics & Monitoring
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACE_SAMPLE_RATE=1.0

# Feature Flags
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_ANALYTICS=true
VITE_LOG_LEVEL=info

# Server-side secrets (for local Supabase Edge Function development)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
AI_GATEWAY_API_KEY=your-api-key
STRIPE_API_KEY=your-stripe-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret
